# DB
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scholarlink

# JWT
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d

# 암호화 키 (서버 자격증명 AES-256-GCM) — openssl rand -hex 32
ENCRYPTION_KEY=your_32byte_hex_encryption_key_here

# 이메일 (Nodemailer + Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=sales@ai-traffic.kr

# 앱 URL (이메일 인증 링크용)
APP_URL=http://localhost:5173
SERVER_URL=http://localhost:3000

# 파일 저장소
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# 서버 설정
PORT=4000
NODE_ENV=development

# Unpaywall API — 무료 OA PDF 조회 (이메일 필요, https://unpaywall.org/products/api)
UNPAYWALL_EMAIL=your_real_email@example.com


# CORE API — OA 전문 검색 (https://core.ac.uk/services/api)
CORE_API_KEY=your_core_api_key_here
